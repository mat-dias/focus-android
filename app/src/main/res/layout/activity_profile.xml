<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D">

    <!-- ══ AVATAR + NOME ═══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/profileHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="44dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- id adicionado + scaleType para Glide carregar a foto corretamente -->
        <ImageView
            android:id="@+id/imgProfileAvatar"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_nav_profile"
            android:background="@drawable/circle_gradient_bg"
            android:padding="18dp"
            android:scaleType="centerCrop"
            android:contentDescription="Avatar"/>

        <TextView
            android:id="@+id/txtProfileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Usuário"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp"/>

        <TextView
            android:id="@+id/txtProfileEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="email@exemplo.com"
            android:textColor="#888888"
            android:textSize="13sp"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <!-- ══ STATS ════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/profileStats"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/profileHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- STREAK card -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_stat_card"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="14dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔥" android:textSize="22sp"/>

            <TextView android:id="@+id/txtProfileStreak"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textColor="#FFFFFF"
                android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="4dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Streak" android:textColor="#888888" android:textSize="11sp"/>
        </LinearLayout>

        <!-- XP card -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_stat_card"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="14dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⭐" android:textSize="22sp"/>

            <TextView android:id="@+id/txtProfileXP"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0 XP" android:textColor="#FFFFFF"
                android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="4dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="XP Total" android:textColor="#888888" android:textSize="11sp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ══ MENU ══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/settingsContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:layout_marginTop="20dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/profileStats"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout android:id="@+id/btnEditProfile" style="@style/MenuRowStyle">
            <TextView style="@style/MenuRowText" android:text="Editar Perfil"/>
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_nav_profile" app:tint="#888888"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnNotifications" style="@style/MenuRowStyle" android:layout_marginTop="8dp">
            <TextView style="@style/MenuRowText" android:text="Notificações"/>
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/icon_notification" app:tint="#888888"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnAbout" style="@style/MenuRowStyle" android:layout_marginTop="8dp">
            <TextView style="@style/MenuRowText" android:text="Sobre o App"/>
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/icon_info" app:tint="#888888"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnLogout" style="@style/MenuRowStyle" android:layout_marginTop="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Sair"
                android:textColor="#EC4899"
                android:textSize="15sp"/>
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/icon_logout" app:tint="#EC4899"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ══ BOTTOM NAV ════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:background="@drawable/bg_bottom_nav"
        android:orientation="horizontal"
        android:gravity="center"
        android:weightSum="5"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:elevation="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/navHome" android:layout_width="30dp" android:layout_height="30dp"
                android:src="@drawable/ic_nav_home" android:background="@android:color/transparent"
                android:contentDescription="Início" android:padding="0dp"/>
            <TextView android:id="@+id/lblHome" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Início"
                android:textSize="9sp" android:textColor="#555555" android:layout_marginTop="3dp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/navStats" android:layout_width="30dp" android:layout_height="30dp"
                android:src="@drawable/ic_nav_stats" android:background="@android:color/transparent"
                android:contentDescription="Stats" android:padding="0dp"/>
            <TextView android:id="@+id/lblStats" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Stats"
                android:textSize="9sp" android:textColor="#555555" android:layout_marginTop="3dp"/>
        </LinearLayout>

        <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/navGoals" android:layout_width="30dp" android:layout_height="30dp"
                android:src="@drawable/ic_nav_goals" android:background="@android:color/transparent"
                android:contentDescription="Metas" android:padding="0dp"/>
            <TextView android:id="@+id/lblGoals" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Metas"
                android:textSize="9sp" android:textColor="#555555" android:layout_marginTop="3dp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/navProfile" android:layout_width="30dp" android:layout_height="30dp"
                android:src="@drawable/ic_nav_profile" android:background="@android:color/transparent"
                android:contentDescription="Perfil" android:padding="0dp"/>
            <TextView android:id="@+id/lblProfile" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Perfil"
                android:textSize="9sp" android:textColor="#FFFFFF" android:layout_marginTop="3dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ══ FAB CENTRAL ═════════════════════════════════════════════ -->
    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/btnAdd"
        android:layout_width="62dp"
        android:layout_height="62dp"
        android:background="@drawable/circle_gradient_bg"
        android:src="@android:drawable/ic_input_add"
        android:padding="16dp"
        android:contentDescription="Adicionar tarefa"
        app:tint="#FFFFFF"
        android:elevation="20dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:translationY="31dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>