<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="0dp">

        <!-- ══ LOGO + TÍTULO ═══════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/headerContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="56dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Logo principal do aplicativo com fundo gradiente -->
            <ImageView
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:src="@drawable/robosemfundo"
                android:background="@drawable/circle_gradient_bg"
                android:scaleType="centerCrop"
                android:contentDescription="Logo"/>

            <!-- Título principal da tela de login -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Focus Study"
                android:textColor="#06B6D4"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginTop="14dp"/>

            <!-- Mensagem de boas-vindas -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bem-vindo de volta"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>

            <!-- Subtítulo explicativo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Faça login para continuar"
                android:textColor="#888888"
                android:textSize="13sp"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- ══ CARD FORMULÁRIO ═════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/loginForm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_stat_card"
            android:padding="24dp"
            app:layout_constraintTop_toBottomOf="@id/headerContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Label do campo de email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="E-MAIL"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"/>

            <!-- Campo de entrada de email -->
            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="seu@email.com"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:background="@drawable/input_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="15sp"
                android:inputType="textEmailAddress"
                android:layout_marginBottom="16dp"/>

            <!-- Label do campo de senha -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SENHA"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"/>

            <!-- Campo de entrada de senha -->
            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="••••••••"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:inputType="textPassword"
                android:background="@drawable/input_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="15sp"/>

            <!-- Link para recuperação de senha -->
            <TextView
                android:id="@+id/tvEsqueci"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Esqueci minha senha"
                android:textColor="#06B6D4"
                android:textSize="12sp"
                android:layout_gravity="end"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"/>

            <!-- Botão principal de login -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Entrar"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/btn_gradient_primary"
                android:stateListAnimator="@null"
                android:elevation="6dp"/>

        </LinearLayout>

        <!-- ══ LINK CADASTRO ═══════════════════════════════════════════ -->
        <TextView
            android:id="@+id/tvCadastro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Não tem conta? Cadastre-se"
            android:textColor="#06B6D4"
            android:textSize="14sp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="32dp"
            app:layout_constraintTop_toBottomOf="@id/loginForm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>