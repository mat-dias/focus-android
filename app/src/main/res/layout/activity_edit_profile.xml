<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- ══ HEADER ════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnVoltarEdit"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_nav_home"
                android:background="@android:color/transparent"
                android:contentDescription="Voltar"
                android:padding="4dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Editar Perfil"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <!-- Espaço para centralizar o título -->
            <View
                android:layout_width="36dp"
                android:layout_height="36dp"/>

        </LinearLayout>

        <!-- ══ AVATAR ════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <!-- Foto clicável -->
            <ImageView
                android:id="@+id/imgAvatarEdit"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/ic_nav_profile"
                android:background="@drawable/circle_gradient_bg"
                android:padding="20dp"
                android:scaleType="centerCrop"
                android:contentDescription="Foto de perfil"
                app:tint="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Toque para alterar a foto"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <!-- ══ CAMPOS ════════════════════════════════════════════════ -->

        <!-- NOME -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NOME"
            android:textColor="#666666"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etEditNome"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input_dark"
            android:textColor="#FFFFFF"
            android:textColorHint="#444444"
            android:hint="Seu nome"
            android:textSize="15sp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:inputType="textPersonName"
            android:singleLine="true"
            android:layout_marginBottom="20dp"/>

        <!-- EMAIL -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EMAIL"
            android:textColor="#666666"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etEditEmail"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input_dark"
            android:textColor="#FFFFFF"
            android:textColorHint="#444444"
            android:hint="Seu email"
            android:textSize="15sp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:inputType="textEmailAddress"
            android:singleLine="true"
            android:layout_marginBottom="20dp"/>

        <!-- NOVA SENHA -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NOVA SENHA (opcional)"
            android:textColor="#666666"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etEditSenha"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input_dark"
            android:textColor="#FFFFFF"
            android:textColorHint="#444444"
            android:hint="Deixe em branco para manter"
            android:textSize="15sp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:inputType="textPassword"
            android:singleLine="true"
            android:layout_marginBottom="20dp"/>

        <!-- CONFIRMAR SENHA -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONFIRMAR NOVA SENHA"
            android:textColor="#666666"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etEditConfirmarSenha"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input_dark"
            android:textColor="#FFFFFF"
            android:textColorHint="#444444"
            android:hint="Confirme a nova senha"
            android:textSize="15sp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:inputType="textPassword"
            android:singleLine="true"
            android:layout_marginBottom="32dp"/>

        <!-- BOTÃO SALVAR -->
        <Button
            android:id="@+id/btnSalvarPerfil"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Salvar alterações"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/btn_gradient_primary"
            android:elevation="6dp"
            android:layout_marginBottom="32dp"/>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
