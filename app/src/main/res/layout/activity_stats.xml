<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- ══ HEADER ════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/statsHeader"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="44dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Suas Estatísticas"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Acompanhe seu progresso"
                    android:textColor="#888888"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

            <!-- ══ STREAK + XP ═══════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/statsCards"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                app:layout_constraintTop_toBottomOf="@id/statsHeader"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- STREAK -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_stat_card"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔥"
                        android:textSize="28sp"/>

                    <TextView
                        android:id="@+id/txtStatsStreak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Carregando..."
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Streak Atual"
                        android:textColor="#888888"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

                <!-- XP -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_stat_card"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐"
                        android:textSize="28sp"/>

                    <TextView
                        android:id="@+id/txtStatsXP"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Carregando..."
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Ganho"
                        android:textColor="#888888"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ══ GRÁFICO SEMANAL ════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/chartWeeklyContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical"
                android:padding="24dp"
                app:layout_constraintTop_toBottomOf="@id/statsCards"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Essa Semana"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <!-- Barras injetadas pelo Java -->
                <LinearLayout
                    android:id="@+id/chartWeeklyBars"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:layout_marginBottom="12dp">

                    <!-- Placeholder carregando -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:text="Carregando..."
                        android:textColor="#888888"
                        android:textSize="13sp"/>

                </LinearLayout>

                <!-- Labels dos dias -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="D" android:gravity="center"
                        android:textColor="#888888" android:textSize="11sp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="S" android:gravity="center"
                        android:textColor="#888888" android:textSize="11sp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="T" android:gravity="center"
                        android:textColor="#888888" android:textSize="11sp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Q" android:gravity="center"
                        android:textColor="#888888" android:textSize="11sp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Q" android:gravity="center"
                        android:textColor="#888888" android:textSize="11sp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="S" android:gravity="center"
                        android:textColor="#888888" android:textSize="11sp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="S" android:gravity="center"
                        android:textColor="#888888" android:textSize="11sp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ══ GRÁFICO MENSAL (TAGS) ══════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/chartMonthlyContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical"
                android:padding="24dp"
                app:layout_constraintTop_toBottomOf="@id/chartWeeklyContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Esse Mês — Por Etiqueta"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Carregando..."
                    android:textSize="40sp"
                    android:layout_marginBottom="16dp"/>

                <!-- Legenda injetada pelo Java -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Carregando..."
                    android:textColor="#888888"
                    android:textSize="13sp"/>

            </LinearLayout>

            <!-- ══ STATUS HOJE ════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/todayStats"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_stat_card"
                android:padding="20dp"
                android:elevation="4dp"
                app:layout_constraintTop_toBottomOf="@id/chartMonthlyContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/txtTodayTasks"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tarefas Hoje"
                        android:textColor="#888888"
                        android:textSize="12sp"/>

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="40dp"
                    android:background="#333333"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/txtTodayCompleted"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#4ADE80"
                        android:textSize="24sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Concluídas"
                        android:textColor="#888888"
                        android:textSize="12sp"/>

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="40dp"
                    android:background="#333333"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/txtTodayXP"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#EC4899"
                        android:textSize="24sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="XP Hoje"
                        android:textColor="#888888"
                        android:textSize="12sp"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ══ BOTTOM NAV ════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:background="@drawable/bg_bottom_nav"
        android:orientation="horizontal"
        android:gravity="center"
        android:weightSum="5"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:elevation="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/navHome" android:layout_width="30dp" android:layout_height="30dp"
                android:src="@drawable/ic_nav_home" android:background="@android:color/transparent"
                android:contentDescription="Início" android:padding="0dp"/>
            <TextView android:id="@+id/lblHome" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Início"
                android:textSize="9sp" android:textColor="#555555" android:layout_marginTop="3dp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/navStats" android:layout_width="30dp" android:layout_height="30dp"
                android:src="@drawable/ic_nav_stats" android:background="@android:color/transparent"
                android:contentDescription="Stats" android:padding="0dp"/>
            <TextView android:id="@+id/lblStats" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Stats"
                android:textSize="9sp" android:textColor="#FFFFFF" android:layout_marginTop="3dp"/>
        </LinearLayout>

        <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/navGoals" android:layout_width="30dp" android:layout_height="30dp"
                android:src="@drawable/ic_nav_goals" android:background="@android:color/transparent"
                android:contentDescription="Metas" android:padding="0dp"/>
            <TextView android:id="@+id/lblGoals" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Metas"
                android:textSize="9sp" android:textColor="#555555" android:layout_marginTop="3dp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/navProfile" android:layout_width="30dp" android:layout_height="30dp"
                android:src="@drawable/ic_nav_profile" android:background="@android:color/transparent"
                android:contentDescription="Perfil" android:padding="0dp"/>
            <TextView android:id="@+id/lblProfile" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Perfil"
                android:textSize="9sp" android:textColor="#555555" android:layout_marginTop="3dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ══ FAB CENTRAL ═════════════════════════════════════════════ -->
    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/btnAdd"
        android:layout_width="62dp"
        android:layout_height="62dp"
        android:background="@drawable/circle_gradient_bg"
        android:src="@android:drawable/ic_input_add"
        android:padding="16dp"
        android:contentDescription="Adicionar tarefa"
        app:tint="#FFFFFF"
        android:elevation="20dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:translationY="31dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>