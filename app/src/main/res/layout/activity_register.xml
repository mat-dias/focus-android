<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="0dp">

        <!-- ══ LOGO + TÍTULO ═══════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/headerContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="48dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Logo principal do aplicativo com fundo gradiente -->
            <ImageView
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:src="@drawable/robosemfundo"
                android:background="@drawable/circle_gradient_bg"
                android:scaleType="centerCrop"
                android:contentDescription="Logo"/>

            <!-- Título principal da tela de cadastro -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Focus Study"
                android:textColor="#06B6D4"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="14dp"/>

            <!-- Mensagem principal de cadastro -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Criar sua conta"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>

            <!-- Subtítulo explicativo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Preencha os dados para começar"
                android:textColor="#888888"
                android:textSize="13sp"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- ══ CARD FORMULÁRIO ═════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/registerForm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="28dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_stat_card"
            android:padding="24dp"
            app:layout_constraintTop_toBottomOf="@id/headerContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- ══ CAMPO NOME COMPLETO ═══════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NOME COMPLETO"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"/>

            <!-- Campo de entrada do nome completo -->
            <EditText
                android:id="@+id/etNome"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Seu nome completo"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:background="@drawable/input_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="15sp"
                android:inputType="textPersonName"
                android:layout_marginBottom="16dp"/>

            <!-- ══ CAMPO E-MAIL ═══════════════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="E-MAIL"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"/>

            <!-- Campo de entrada de email -->
            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="seu@email.com"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:background="@drawable/input_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="15sp"
                android:inputType="textEmailAddress"
                android:layout_marginBottom="16dp"/>

            <!-- ══ CAMPO SENHA ════════════════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SENHA"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"/>

            <!-- Campo de entrada de senha -->
            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Mínimo 6 caracteres"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:inputType="textPassword"
                android:background="@drawable/input_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="15sp"
                android:layout_marginBottom="16dp"/>

            <!-- ══ CAMPO DATA DE NASCIMENTO ═══════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DATA DE NASCIMENTO"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"/>

            <!-- Container clicável que abre DatePicker -->
            <LinearLayout
                android:id="@+id/layoutDataNasc"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/input_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true">

                <!-- Texto da data selecionada -->
                <TextView
                    android:id="@+id/tvDataNasc"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="DD/MM/AAAA"
                    android:textColor="#555555"
                    android:textSize="15sp"/>

                <!-- Ícone do calendário -->
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/icon_calendar"
                    app:tint="#888888"
                    android:contentDescription="Calendário"/>

            </LinearLayout>

            <!-- ══ SELETOR DE SEXO ═══════════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SEXO"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"/>

            <!-- Grupo de botões de rádio para seleção de sexo -->
            <RadioGroup
                android:id="@+id/rgSexo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <!-- Opção Masculino -->
                <RadioButton
                    android:id="@+id/rbMasculino"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Masculino"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:gravity="center_vertical"
                    android:buttonTint="#06B6D4"
                    android:paddingStart="6dp"/>

                <!-- Opção Feminino -->
                <RadioButton
                    android:id="@+id/rbFeminino"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Feminino"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:gravity="center_vertical"
                    android:buttonTint="#EC4899"
                    android:paddingStart="6dp"/>

                <!-- Opção Outro -->
                <RadioButton
                    android:id="@+id/rbOutro"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Outro"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:gravity="center_vertical"
                    android:buttonTint="#888888"
                    android:paddingStart="6dp"/>

            </RadioGroup>

            <!-- ══ BOTÃO CRIAR CONTA ═════════════════════════════════════ -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Criar conta"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/btn_gradient_primary"
                android:stateListAnimator="@null"
                android:elevation="6dp"/>

        </LinearLayout>

        <!-- ══ LINK LOGIN ═════════════════════════════════════════════ -->
        <TextView
            android:id="@+id/tvJaTenho"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Já tem conta? Entrar"
            android:textColor="#06B6D4"
            android:textSize="14sp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="36dp"
            app:layout_constraintTop_toBottomOf="@id/registerForm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>