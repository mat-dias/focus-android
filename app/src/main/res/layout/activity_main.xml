<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D">

    <!-- ══ HEADER ══════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="40dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Olá, Usuário!"
                android:textColor="#FFFFFF"
                android:textSize="19sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vamos focar hoje? 🎯"
                android:textColor="#888888"
                android:textSize="13sp"
                android:layout_marginTop="3dp"/>

        </LinearLayout>

        <!-- STREAK badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@drawable/bg_stat_card"
            android:layout_marginEnd="8dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔥" android:textSize="13sp"/>

            <TextView
                android:id="@+id/txtStreak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- XP badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@drawable/bg_stat_card">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⭐" android:textSize="13sp"/>

            <TextView
                android:id="@+id/txtXP"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 XP"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ══ MASCOTE ══════════════════════════════════════════════════ -->
    <ImageView
        android:id="@+id/imgRobo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="22dp"
        android:background="@drawable/circle_gradient_bg"
        android:src="@drawable/robosemfundo"
        android:scaleType="centerCrop"
        android:contentDescription="Mascote"
        android:elevation="8dp"
        android:padding="4dp"
        app:layout_constraintTop_toBottomOf="@id/headerContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ══ TIMER CARD ════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/timerContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_stat_card"
        android:padding="18dp"
        android:elevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/imgRobo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnMinus"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/circle_pink_btn"
            android:src="@drawable/icon_remove"
            android:padding="12dp"
            android:contentDescription="Diminuir"
            app:tint="#FFFFFF"
            android:elevation="4dp"/>

        <TextView
            android:id="@+id/txtTimer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="25:00"
            android:textColor="#FFFFFF"
            android:textSize="50sp"
            android:textStyle="bold"
            android:gravity="center"
            android:fontFamily="monospace"/>

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnPlus"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/circle_pink_btn"
            android:src="@drawable/icon_add"
            android:padding="12dp"
            android:contentDescription="Aumentar"
            app:tint="#FFFFFF"
            android:elevation="4dp"/>

    </LinearLayout>

    <!-- ══ BOTÃO INICIAR ════════════════════════════════════════════ -->
    <Button
        android:id="@+id/btnStart"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Entrar no modo foco"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:background="@drawable/btn_gradient_primary"
        android:layout_marginTop="16dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:elevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/timerContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ══ PAUSA / RESET ════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/controlButtons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/btnStart"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnPause"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Pausar"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/btn_pause"
            android:layout_marginEnd="8dp"
            android:elevation="4dp"/>

        <Button
            android:id="@+id/btnReset"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Reiniciar"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/btn_reset"
            android:elevation="4dp"/>

    </LinearLayout>

    <!-- ══ STATUS ════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="12dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_stat_card"
        android:padding="11dp"
        android:elevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/controlButtons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/dot_cyan"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pronto para focar!"
            android:textColor="#AAAAAA"
            android:textSize="13sp"/>

    </LinearLayout>

    <!-- ══ FRAGMENT CONTAINER ════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ══ BOTTOM NAV ════════════════════════════════════════════════ -->
    <!--
        Cole este bloco substituindo o <LinearLayout id="bottomNav">
        em: activity_main.xml, activity_tasks.xml, activity_profile.xml
        ATENÇÃO: o ConstraintLayout pai precisa ter:
        xmlns:app="http://schemas.android.com/apk/res-auto"
    -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:background="@drawable/bg_bottom_nav"
        android:orientation="horizontal"
        android:gravity="center"
        android:weightSum="5"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:elevation="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- HOME -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/navHome"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_nav_home"
                android:background="@android:color/transparent"
                android:contentDescription="Início"
                android:padding="0dp"/>

            <TextView
                android:id="@+id/lblHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Início"
                android:textSize="9sp"
                android:textColor="#555555"
                android:layout_marginTop="3dp"/>

        </LinearLayout>

        <!-- STATS -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/navStats"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_nav_stats"
                android:background="@android:color/transparent"
                android:contentDescription="Stats"
                android:padding="0dp"/>

            <TextView
                android:id="@+id/lblStats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stats"
                android:textSize="9sp"
                android:textColor="#555555"
                android:layout_marginTop="3dp"/>

        </LinearLayout>

        <!-- ESPAÇO PARA O FAB -->
        <Space
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- METAS -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/navGoals"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_nav_goals"
                android:background="@android:color/transparent"
                android:contentDescription="Metas"
                android:padding="0dp"/>

            <TextView
                android:id="@+id/lblGoals"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Metas"
                android:textSize="9sp"
                android:textColor="#555555"
                android:layout_marginTop="3dp"/>

        </LinearLayout>

        <!-- PERFIL -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/navProfile"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_nav_profile"
                android:background="@android:color/transparent"
                android:contentDescription="Perfil"
                android:padding="0dp"/>

            <TextView
                android:id="@+id/lblProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perfil"
                android:textSize="9sp"
                android:textColor="#555555"
                android:layout_marginTop="3dp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- ══ FAB CENTRAL ══════════════════════════════════════════════ -->
    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/btnAdd"
        android:layout_width="62dp"
        android:layout_height="62dp"
        android:background="@drawable/circle_gradient_bg"
        android:src="@android:drawable/ic_input_add"
        android:padding="16dp"
        android:contentDescription="Adicionar tarefa"
        app:tint="#FFFFFF"
        android:elevation="20dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:translationY="31dp"/>

    <androidx.constraintlayout.widget.Guideline android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

</androidx.constraintlayout.widget.ConstraintLayout>